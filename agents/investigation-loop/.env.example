# Copy to .env (gitignored). Same Azure OpenAI values as the team's LADP .env.
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_ENDPOINT=https://oai-ladp-ncs-4.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-5.4-mini-ncs4-group4

# In-cluster default: http://kagent-tools.kagent:8084/mcp
# For local dev: kubectl -n kagent port-forward svc/kagent-tools 8084:8084, then:
MCP_SERVER_URL=http://localhost:8084/mcp
