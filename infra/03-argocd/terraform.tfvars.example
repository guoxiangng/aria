# Copy to terraform.tfvars (gitignored) and fill in. Secrets never go in git.
region       = "ap-southeast-1"
cluster_name = "aria"

argocd_chart_version = "10.1.0" # verify latest: https://github.com/argoproj/argo-helm


azure_openai_api_key = "xxx"  # from your LADP .env (AZURE_OPENAI_API_KEY)

langfuse_public_key = "pk-lf-xxx"  # from your LADP .env (LANGFUSE_PUBLIC_KEY)
langfuse_secret_key = "sk-lf-xxx"  # from your LADP .env (LANGFUSE_SECRET_KEY)
# langfuse_otel_endpoint default is US region — override if your project is EU/JP/HIPAA
